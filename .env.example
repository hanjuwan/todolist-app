# ─────────────────────────────────────────────────────────
# TodoListApp 환경 변수 템플릿
# 사용법: 이 파일을 `.env`로 복사한 뒤 값을 실제 값으로 교체
# 주의: `.env`는 절대 커밋 금지 (이미 .gitignore에 포함)
# ─────────────────────────────────────────────────────────

# Database (pg 라이브러리 단일 URL 방식)
POSTGRES_CONNECTION_STRING=postgresql://<user>:<password>@<host>:<port>/<database>

# Backend (Express)
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=<32자 이상 랜덤 문자열로 교체>
JWT_ACCESS_TOKEN_TTL=1h
BCRYPT_COST=12
